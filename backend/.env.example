# =============================================================================
# Variáveis de ambiente — Sistema Ludoteca
# Copie este arquivo para `.env` e ajuste os valores conforme o ambiente.
#   cp .env.example .env
#
# IMPORTANTE (Docker Compose):
#   Ao rodar via `docker-compose up`, os hosts MYSQL_HOST e RABBITMQ_HOST
#   devem apontar para os NOMES DOS SERVIÇOS (mysql / rabbitmq), e não
#   "localhost". O docker-compose.yml já injeta esses valores corretos.
#   Estes defaults (localhost) servem para execução LOCAL fora do Docker.
# =============================================================================

APP_NAME=Ludoteca

# ----------------------------- Banco de Dados (MySQL) ------------------------
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_DATABASE=ludoteca
MYSQL_USER=ludoteca_user
MYSQL_PASSWORD=ludoteca_pass
# Senha do root (usada apenas pelo container MySQL no docker-compose)
MYSQL_ROOT_PASSWORD=root

# ----------------------------------- JWT ------------------------------------
JWT_SECRET_KEY=super_secret_key_change_me_in_production
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=60

# --------------------------------- RabbitMQ ---------------------------------
RABBITMQ_HOST=localhost
RABBITMQ_PORT=5672
RABBITMQ_USER=guest
RABBITMQ_PASSWORD=guest

# --------------------------------- Grafana ----------------------------------
GF_SECURITY_ADMIN_USER=admin
GF_SECURITY_ADMIN_PASSWORD=admin
